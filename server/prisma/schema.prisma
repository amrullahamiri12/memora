generator client {
  provider      = "prisma-client-js"
  // native: local macOS/Linux dev; rhel-openssl-3.0.x: Vercel serverless (Linux)
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum ProgressStatus {
  GOT_IT
  NEEDS_PRACTICE
}

enum QuestionType {
  MCQ
  TRUE_FALSE
  FILL_BLANK
}

enum AuditSource {
  APP
  DB_TRIGGER
}

model User {
  id                        String              @id @default(cuid())
  name                      String
  email                     String              @unique
  passwordHash              String?             @map("password_hash")
  googleId                  String?             @unique @map("google_id")
  emailVerifiedAt           DateTime?           @map("email_verified_at")
  verificationTokenHash     String?             @map("verification_token_hash")
  verificationTokenExpires  DateTime?           @map("verification_token_expires")
  resetTokenHash            String?             @map("reset_token_hash")
  resetTokenExpires         DateTime?           @map("reset_token_expires")
  role                      Role                @default(USER)
  plan                      String              @default("FREE")
  stripeCustomerId          String?             @map("stripe_customer_id")
  planRenewsAt              DateTime?           @map("plan_renews_at")
  deactivatedAt             DateTime?           @map("deactivated_at")
  createdAt                 DateTime            @default(now()) @map("created_at")
  progress                  UserProgress[]
  dailyPractice             UserDailyPractice[]
  subjects                  UserSubject[]
  guestDeviceBinding        GuestDeviceBinding?

  @@index([stripeCustomerId])
  @@map("users")
}

model GuestDeviceBinding {
  deviceId  String   @id @map("device_id")
  userId    String   @unique @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("guest_device_bindings")
}

model Subject {
  id     String        @id @default(cuid())
  name   String        @unique
  topics Topic[]
  users  UserSubject[]

  @@map("subjects")
}

model UserSubject {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  subjectId String   @map("subject_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([userId, subjectId])
  @@index([userId])
  @@map("user_subjects")
}

model Topic {
  id         String      @id @default(cuid())
  subjectId  String      @map("subject_id")
  name       String
  subject    Subject     @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  flashcards Flashcard[]

  @@unique([subjectId, name])
  @@index([subjectId])
  @@map("topics")
}

model Flashcard {
  id           String         @id @default(cuid())
  topicId      String         @map("topic_id")
  questionType QuestionType   @default(MCQ) @map("question_type")
  question     String
  answer       String
  distractor1  String?        @map("distractor_1")
  distractor2  String?        @map("distractor_2")
  distractor3  String?        @map("distractor_3")
  difficulty   Difficulty
  topic       Topic          @relation(fields: [topicId], references: [id], onDelete: Cascade)
  progress    UserProgress[]

  @@index([topicId])
  @@map("flashcards")
}

model UserProgress {
  id           String         @id @default(cuid())
  userId       String         @map("user_id")
  flashcardId  String         @map("flashcard_id")
  status       ProgressStatus
  lastReviewed DateTime       @default(now()) @map("last_reviewed")
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  flashcard    Flashcard      @relation(fields: [flashcardId], references: [id], onDelete: Cascade)

  @@unique([userId, flashcardId])
  @@index([userId])
  @@map("user_progress")
}

model UserDailyPractice {
  id     String   @id @default(cuid())
  userId String   @map("user_id")
  date   DateTime
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("user_daily_practice")
}

model AuditEvent {
  id           String      @id @default(cuid())
  occurredAt   DateTime    @default(now()) @map("occurred_at")
  source       AuditSource @default(APP)
  action       String
  actorUserId  String?     @map("actor_user_id")
  actorEmail   String?     @map("actor_email")
  actorRole    String?     @map("actor_role")
  entityType   String?     @map("entity_type")
  entityId     String?     @map("entity_id")
  targetUserId String?     @map("target_user_id")
  ipAddress    String?     @map("ip_address")
  userAgent    String?     @map("user_agent")
  metadata     Json?

  @@index([occurredAt(sort: Desc)])
  @@index([action])
  @@index([actorUserId])
  @@index([targetUserId])
  @@index([entityType, entityId])
  @@map("audit_events")
}
