# Supabase / PostgreSQL (required for Vercel)
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"

# Local SQLite (optional): use provider sqlite in schema.prisma and DATABASE_URL="file:./dev.db"

# At least 32 characters (required in production)
JWT_SECRET="change-this-to-a-long-random-secret-at-least-32-chars"
JWT_EXPIRES_IN="7d"
# Use 5001 — macOS AirPlay Receiver occupies port 5000
PORT=5001
CLIENT_URL="http://localhost:5173"
APP_URL="http://localhost:5173"

# Email (Resend) — verification + password reset
# RESEND_API_KEY="re_..."
# Use Resend test sender until memora.cards domain is verified in Resend:
# EMAIL_FROM="Memora <onboarding@resend.dev>"
# EMAIL_FROM="Memora <noreply@memora.cards>"

# Google sign-in (OAuth 2.0 Web client ID)
# GOOGLE_CLIENT_ID="....apps.googleusercontent.com"

# Optional limits
# MAX_STUDY_CARDS=500
# MAX_CSV_BYTES=2097152
