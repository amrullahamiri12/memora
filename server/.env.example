# Local development (SQLite — works out of the box)
DATABASE_URL="file:./dev.db"

# For Supabase PostgreSQL, replace the line above with:
# DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"
# Also change provider in prisma/schema.prisma from "sqlite" to "postgresql" and add directUrl.

# At least 32 characters (required in production)
JWT_SECRET="change-this-to-a-long-random-secret-at-least-32-chars"
JWT_EXPIRES_IN="7d"
# Use 5001 — macOS AirPlay Receiver occupies port 5000
PORT=5001
CLIENT_URL="http://localhost:5173"
# Optional limits
# MAX_STUDY_CARDS=500
# MAX_CSV_BYTES=2097152
