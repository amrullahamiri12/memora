{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install && npm install --prefix server --omit=dev && npm install --prefix client --include=dev",
  "buildCommand": "npm run build:vercel",
  "outputDirectory": "client/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "memory": 1024,
      "excludeFiles": "{server/node_modules/@prisma/engines/**/libquery_engine-darwin*,server/node_modules/@prisma/engines/**/schema-engine-darwin*,server/node_modules/.prisma/client/libquery_engine-darwin*,server/node_modules/prisma/**/libquery_engine-darwin*,server/node_modules/prisma/**/schema-engine-darwin*}"
    }
  }
}
