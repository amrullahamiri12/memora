# Public site URL for canonical links and Open Graph (production: https://memora.cards)
# VITE_SITE_URL="https://memora.cards"

# Google sign-in — required for the login/register button (Vite reads this file only).
# Use the same OAuth 2.0 Web client ID as GOOGLE_CLIENT_ID in server/.env.
# Restart `npm run dev` after changing this file.
# VITE_GOOGLE_CLIENT_ID="....apps.googleusercontent.com"
